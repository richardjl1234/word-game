# ===== 后端配置（拷贝为 .env 后填入实际值，.env 已在 .gitignore）=====

# FastAPI
APP_HOST=0.0.0.0
APP_PORT=8000
APP_DEBUG=true
CORS_ORIGINS=http://localhost:8080,http://127.0.0.1:8080

# Database（生产用 Postgres；测试用 sqlite:///:memory:）
DATABASE_URL=postgresql://wordgame:wordgame@postgres:5432/wordgame
TEST_DATABASE_URL=sqlite:///:memory:

# Redis / Celery
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1

# S3-compatible（开发用 MinIO）
S3_ENDPOINT=http://minio:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=wordgame-uploads
S3_REGION=us-east-1

# File upload limits
MAX_UPLOAD_SIZE_MB=200

# spaCy 模型（首次运行时自动下载）
SPACY_MODEL=en_core_web_sm

# ===== 凭据（不提交到 git，从外部加载）=====
# LLM API key（task #14 选型后填入）
# OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...
# DEEPGRAM_API_KEY=...